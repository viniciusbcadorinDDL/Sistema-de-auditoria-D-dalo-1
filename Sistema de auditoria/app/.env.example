# =========================================
# Dédalo — Variáveis de ambiente
# Copie este arquivo para .env e preencha
# =========================================

# --- Base ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Auth.js (NextAuth v5) ---
# Gere com: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# --- Google SSO ---
# Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_ID=
GOOGLE_SECRET=

# --- Microsoft Entra ID (Azure AD) ---
# Portal: https://entra.microsoft.com → App registrations
# Redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/callback/microsoft-entra-id
MS_ENTRA_ID=
MS_ENTRA_SECRET=
MS_ENTRA_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# --- Database (Supabase Postgres) ---
# Settings → Database → Connection string (use o pooler para produção)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[REF].supabase.co:5432/postgres

# --- Supabase Storage ---
NEXT_PUBLIC_SUPABASE_URL=https://[REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (e-mail) ---
# https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM="Dédalo Auditoria <nao-responder@dedalo.com.br>"
EMAIL_FINANCEIRO=financeiro@dedalo.com.br

# --- Inngest (jobs agendados) ---
# https://app.inngest.com → settings → keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Gotenberg (DOCX → PDF) ---
# Deploy em https://fly.io/docs/app-guides/gotenberg/
GOTENBERG_URL=https://gotenberg-dedalo.fly.dev

# --- Sentry ---
SENTRY_DSN=
SENTRY_ORG=dedalo
SENTRY_PROJECT=auditorias
SENTRY_AUTH_TOKEN=

# --- Vercel (apenas em produção) ---
VERCEL_URL=
